{
  "name": "hk-bau-website",
  "version": "1.0.0",
  "description": "HK Bau Website Optimization",
  "scripts": {
    "audit:site": "node scripts/audit-site.js",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.min.css --minify",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.min.css --watch",
    "build:posts": "node scripts/build-posts.js",
    "build:webp": "node scripts/convert-webp.js",
    "swap:webp": "node scripts/swap-jpg-to-webp.js",
    "audit:sitemap": "node scripts/audit-sitemap.js"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1"
  }
}
